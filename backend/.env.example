APP_NAME=trip-planning-agent
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# 高德前端地图 JS SDK 配置
# 这里请填写 Web端(JS API) Key，而不是 Web服务 Key
AMAP_API_KEY=
# 如果你的 JS API Key 开启了安全校验，这里填写安全密钥
AMAP_SECURITY_JS_CODE=

# sugarforever/amap-mcp-server 启动配置
# 推荐使用 uvx amap-mcp-server；如果系统 PATH 里没有 uvx，后端会自动尝试 backend/venv 或 backend/.venv 下的 uvx.exe
AMAP_MCP_COMMAND=uvx
AMAP_MCP_ARGS=["amap-mcp-server", "stdio"]
# 这里的 AMAP_MAPS_API_KEY 应填写高德 Web服务 Key，供 MCP Server 调用地图服务
AMAP_MCP_ENV={"AMAP_MAPS_API_KEY":""}

# 默认工具名；系统也会在运行时尝试自动识别实际工具名
AMAP_MCP_TOOL_POI_SEARCH=maps_text_search
AMAP_MCP_TOOL_ROUTE_PLAN=maps_direction_driving_by_address
AMAP_MCP_TOOL_WEATHER=maps_weather
AMAP_MCP_TIMEOUT_SECONDS=20
ENABLE_MOCK_MCP=true
